HOST=0.0.0.0
PORT=8080
COMMAND_START=["/"]
COMMAND_SEP=["."]
SUPERUSERS=[]
CUSTOM_PLUGINS=[]

# ── data directory ─────────────────────────────────────────────────────────────
# Root directory for all plugin persistent data files.  Can be an absolute path
# or a path relative to the working directory.
# Default: data  (i.e. <cwd>/data/)
DATA_DIR=data

# ── language ──────────────────────────────────────────────────────────────────
# Bot UI language for command responses.  Affects /ping, /help, /notice output.
# en  – English (default)
# zh  – 简体中文 / Simplified Chinese
BOT_LANGUAGE=zh

# ── logging ───────────────────────────────────────────────────────────────────
# On-disk log files with automatic rotation and cleanup.
# LOG_DIR          – directory where log files are written (default: logs)
# LOG_ROTATION     – loguru rotation spec: a time ("00:00" = daily at midnight),
#                    a size ("10 MB"), or a timedelta ("1 week")
# LOG_RETENTION    – how long to keep rotated files ("30 days", "4 weeks", …)
# LOG_LEVEL_FILE   – minimum level written to disk (DEBUG/INFO/WARNING/ERROR)
LOG_DIR=logs
LOG_ROTATION=00:00
LOG_RETENTION=30 days
LOG_LEVEL_FILE=INFO

# ── error reporting ───────────────────────────────────────────────────────────
# Controls which superusers receive error reports from ALL plugins
# (unhandled matcher exceptions via exception_hook, ntfy send failures, etc.)
#
# "all"            – every UID listed in SUPERUSERS (default)
# []               – disable error reporting entirely
# [123456, 789012] – only the listed UIDs (must be a subset of SUPERUSERS)
ERROR_REPORT_SUPERUSERS=all

# ── image font ────────────────────────────────────────────────────────────────
# Absolute path to a CJK-capable TrueType/OpenType font file.
# Auto-detected from common system paths if empty.
# For anti-aliased text fallback, set this to a valid TTF/OTF/TTC font path.
# Shared by all image-generating plugins (b23extract, mcping, …).
CARD_FONT=
# Preferred TTC/OTC face weight: regular | medium | bold (ignored for TTF/OTF)
CARD_FONT_WEIGHT=medium
# Preferred CJK language variant when using a pan-CJK TTC/OTC collection:
#   sc – Simplified Chinese (default; avoids Japanese glyph variants)
#   tc – Traditional Chinese
#   jp – Japanese
#   kr – Korean
#   hk – Hong Kong (Traditional Chinese, HK-specific variants)
#   (empty) – use first face matching the requested weight
CARD_FONT_LANG=sc

# ── anti_miniapp ──────────────────────────────────────────────────────────────
# Regex keywords – messages matching any of these will be ignored.
ANTI_MINIAPP_IGNORED_KEYWORDS=["music.163.com", "y.qq.com", "(b23.tv)|(bili(22|23|33|2233).cn)", "mqqapi://"]

# ── b23extract ────────────────────────────────────────────────────────────────
# Bilibili credentials (optional for non-paid content, but lower rate limits).
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_BUVID3=
# HTTP proxy for bilibili-api requests (e.g. http://127.0.0.1:7890)
BILIBILI_PROXY=
# Truncate descriptions at this many characters in text mode (0 = unlimited)
BILIBILI_DESC_MAX_LEN=180
# Image card generation mode: auto (image when cover available) | on | off
BILIBILI_IMAGE_MODE=auto
# Max description lines rendered in the image card (0 = unlimited)
BILIBILI_IMAGE_DESC_MAX_LINES=12
# Content filter lists ([] by default). If any rule matches, b23extract will not reply.
# Literal lists are case-insensitive substring matches.
# Regex lists are Python regular expressions.
BILIBILI_FILTER_UPLOADER_NAMES=[]
BILIBILI_FILTER_UPLOADER_NAME_REGEX=[]
BILIBILI_FILTER_UPLOADER_UIDS=[]
BILIBILI_FILTER_TITLES=[]
BILIBILI_FILTER_TITLE_REGEX=[]
BILIBILI_FILTER_DESCRIPTIONS=[]
BILIBILI_FILTER_DESCRIPTION_REGEX=[]
BILIBILI_FILTER_TAGS=[]
BILIBILI_FILTER_TAG_REGEX=[]
BILIBILI_FILTER_CATEGORIES=[]
BILIBILI_FILTER_CATEGORY_REGEX=[]
# Sender UIDs bypassing all content filters (superusers always bypass)
BILIBILI_FILTER_SENDER_WHITELIST=[]
# Optional reject response when filtered:
# - set text only (plain text), image only (local file path), or both
BILIBILI_FILTER_REJECT_TEXT=
BILIBILI_FILTER_REJECT_IMAGE=

# ── group_notice ──────────────────────────────────────────────────────────────
# Global default templates for group join/leave events.
# These apply to all groups unless overridden per-group with /notice.
# Placeholders: #userid (QQ number), #username (display name / nickname)
# Set to empty string to disable that notice type globally.
GROUP_JOIN_MSG=
GROUP_LEAVE_MSG=
# Per-group templates are stored automatically in <DATA_DIR>/group_notice.json.
# Use /notice in a group to view or change templates for that group.

# ── withdraw ──────────────────────────────────────────────────────────────────
# How many sent messages to remember per conversation
WITHDRAW_MAX_HISTORY=200

# ── mcping ────────────────────────────────────────────────────────────────────
# Image card generation mode: auto (image when favicon available) | on | off
MCPING_IMAGE_MODE=auto

# ── ntfy ──────────────────────────────────────────────────────────────────────
# Forward messages from ntfy.sh channels to QQ groups/users.
# NTFY_SERVER        – base URL of your ntfy server (default: https://ntfy.sh)
# NTFY_TOKEN         – Bearer token for authenticated ntfy servers (leave empty for public)
# NTFY_RECONNECT_INTERVAL – seconds between reconnect attempts on error (default: 10)
# NTFY_CACHE_CLEAN_INTERVAL – minutes between media-cache sweeps (default: 60)
# NTFY_TO_QQ_MAPPING – list of {ntfy_channel: str, qq_targets: list[str]} mappings
#                      qq_targets format: "group_<id>" or "user_<id>"
# NTFY_ATTACHMENT_HOST_MAPPING – substitute download hosts, e.g. {"https://cdn.example.com/": "https://cdn.example.org/"}
# Send failures are reported via ERROR_REPORT_SUPERUSERS (see above).
NTFY_SERVER=https://ntfy.sh
NTFY_TOKEN=
NTFY_RECONNECT_INTERVAL=10
NTFY_CACHE_CLEAN_INTERVAL=60
NTFY_TO_QQ_MAPPING=[]
NTFY_ATTACHMENT_HOST_MAPPING={}

# ── drasl ─────────────────────────────────────────────────────────────────────
# Generate Drasl Minecraft auth-server invite links via /invite command.
# DRASL_SERVER        – base URL of your Drasl server (required)
# DRASL_TOKEN         – API bearer token (required)
# DRASL_ALLOWED_GROUPS – group IDs whose members may use /invite
# DRASL_ALLOWED_USERS  – user IDs allowed to use /invite in private chat
# DRASL_LIMIT          – max invites per non-superuser user (0 = unlimited, default: 1)
# Invite counts are stored automatically in <DATA_DIR>/drasl/record.json.
# To ban a specific user, use the service controller:
#   /svc off drasl @user        (in a group, by group admin)
#   /svc off drasl -u <uid>     (in PM, superuser only)
DRASL_SERVER=
DRASL_TOKEN=
DRASL_ALLOWED_GROUPS=[]
DRASL_ALLOWED_USERS=[]
DRASL_LIMIT=1
